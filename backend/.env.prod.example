# База данных PostgreSQL
DATABASE_URL=postgresql://gallery_user:CHANGE_THIS_STRONG_PASSWORD_123@postgres:5432/gallery_db

# JWT секретный ключ (ОБЯЗАТЕЛЬНО ИЗМЕНИТЕ!)
SECRET_KEY=CHANGE_THIS_TO_RANDOM_SECRET_KEY_MIN_32_CHARS_LONG_123456789

# JWT настройки
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Тип хранилища: "local" или "google_drive_oauth"
STORAGE_TYPE=local

# Google Drive (опционально, если STORAGE_TYPE=google_drive_oauth)
# GOOGLE_CREDENTIALS_PATH=./oauth_credentials.json
# GOOGLE_DRIVE_FOLDER_ID=your-drive-folder-id

# CORS (разрешенные домены через запятую)
CORS_ORIGINS=https://gallery.fatbox.org,http://localhost:5173

# Загрузка файлов
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE=10485760
