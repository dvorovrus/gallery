ENVIRONMENT=development
DATABASE_URL=sqlite:///./gallery.db
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Storage Type
STORAGE_TYPE=google_drive

# Google Drive Configuration
GOOGLE_CREDENTIALS_PATH=./service-account.json
GOOGLE_DRIVE_FOLDER_ID=your-drive-folder-id-here

# CORS
CORS_ORIGINS=https://gallery.fatbox.org,http://localhost:5173

# Vercel Cron shared secret — required for the scheduled cleanup endpoint.
# Generate with: openssl rand -base64 32
# Then set the same value in Vercel project settings so cron requests are
# sent as "Authorization: Bearer <CRON_SECRET>".
CRON_SECRET=

